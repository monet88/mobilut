{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@features/*": ["src/features/*"],
      "@services/*": ["src/services/*"],
      "@adapters/*": ["src/adapters/*"],
      "@ui/*": ["src/ui/*"],
      "@theme": ["src/theme"],
      "@theme/*": ["src/theme/*"],
      "@hooks": ["src/hooks"],
      "@hooks/*": ["src/hooks/*"],
      "@lib": ["src/lib"],
      "@lib/*": ["src/lib/*"],
      "@i18n": ["src/i18n"],
      "@i18n/*": ["src/i18n/*"],
      "@lut-core": ["packages/lut-core/src"],
      "@lut-core/*": ["packages/lut-core/src/*"]
    }
  },
  "include": ["app", "src", "packages", "expo-env.d.ts"],
  "exclude": ["node_modules", "__tests__"]
}
